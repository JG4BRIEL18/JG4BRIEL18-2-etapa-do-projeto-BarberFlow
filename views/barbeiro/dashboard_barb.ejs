<!DOCTYPE html>
<html lang="pt-BR">

<%- include('../partials/header') %>

<body>

    <%- include('../partials/navbar_barbeiro') %>

    <!-- Conteúdo principal -->
    <main>

        <!-- Boas-vindas -->
        <section aria-labelledby="titulo-boas-vindas">
            <h2 id="titulo-boas-vindas">Painel do Barbeiro:</h2>
            <p id="mensagemBoasVindas"></p>
        </section>

        <!-- Estatísticas -->
        <section aria-labelledby="titulo-estatisticas">
            <h2 id="titulo-estatisticas">Visão Geral</h2>

            <div id="estatisticas">
                <p id="totalAgendamentos"></p>
                <p id="atendimentosHoje"></p>
                <p id="faturamento"></p>
            </div>
        </section>

        <!-- Próximos agendamentos -->
        <section aria-labelledby="titulo-agendamentos">
            <h2 id="titulo-agendamentos">Próximos Atendimentos</h2>

            <div class="table-container">

                <table>
                    <caption>Lista de próximos atendimentos</caption>

                    <thead>
                        <tr>
                            <th scope="col">Cliente</th>
                            <th scope="col">Serviço</th>
                            <th scope="col">Data</th>
                            <th scope="col">Horário</th>
                            <th scope="col">Ações</th>
                        </tr>
                    </thead>

                    <tbody id="listaAgendamentos" aria-live="polite">
                        <!-- Conteúdo dinâmico -->
                    </tbody>

                </table>

            </div>
        </section>

        <!-- Ações -->
        <section aria-labelledby="titulo-acoes">
            <h2 id="titulo-acoes">Ações</h2>

            <a href="/barbeiro/agenda" class="botao">Gerenciar Agenda</a>
            <a href="/barbeiro/servicos" class="botao">Gerenciar Serviços</a>
        </section>

    </main>

    <%- include('../partials/footer') %>

    <script src="/js/dashboard_barb.js" defer></script>

</body>
</html>
