<!DOCTYPE html>
<html lang="pt-BR">

<%- include('../partials/header') %>

<body>

    <%- include('../partials/navbar_barbeiro') %>

    <main>

        <section>
            <h2>Agenda de Atendimentos</h2>
            <p>Visualize e gerencie seus agendamentos.</p>
        </section>

        <section>
            <button id="btnGerenciar">Gerenciar Agendamentos</button>
        </section>

        <section>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Cliente</th>
                            <th>Serviço</th>
                            <th>Data</th>
                            <th>Horário</th>
                            <th>Ações</th>
                        </tr>
                    </thead>

                    <tbody id="tabelaAgenda"></tbody>
                </table>
            </div>
        </section>

    </main>

    <!-- MODAL -->
    <div id="modalEditar" class="modal">
        <div class="modal-content">

            <h2>Remarcar Atendimento</h2>

            <form id="formEditar">

                <label>Data</label>
                <input type="date" id="editData" required>

                <label>Horário</label>
                <input type="time" id="editHorario" required>

                <button type="submit">Salvar</button>
                <button type="button" id="btnCancelar">Cancelar</button>

            </form>

        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="/js/agenda.js" defer></script>

</body>
</html>